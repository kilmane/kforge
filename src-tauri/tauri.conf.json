{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "com.kforge.kforge",
  "productName": "KForge",
  "version": "0.1.0",
  "build": {
    "beforeDevCommand": "pnpm run start",
    "beforeBuildCommand": "pnpm run build",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "KForge",
        "width": 1200,
        "height": 800
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      }
    }
  }
}
